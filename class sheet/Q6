class BankAccount :

    def __init__ (self,owner,balance) :
        self.owner = owner
        self.balance = balance

    def deposit (self,amount) :
        self.balance += amount

    def withdraw (self,amount) :
        if self.balance < amount :
            print('This Transaction cant be done')
        else :
            self.balance -= amount
    def show_total (self) :
        print(self.balance)

u1 = BankAccount('ahmed',20000)
u2 = BankAccount('khaled',5000)

u1.deposit(10000)
u1.show_total()

u2.deposit(2000)
u2.show_total()
u2.withdraw(8000)
u2.show_total()
